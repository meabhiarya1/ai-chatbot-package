{
  "name": "ai-chatbot-package",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/ai-chatbot-package.umd.cjs",
  "module": "./dist/ai-chatbot-package.js",
  "style": "./dist/ai-chatbot-package.css",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/ai-chatbot-package.js",
      "require": "./dist/ai-chatbot-package.umd.cjs"
    },
    "./style.css": "./dist/ai-chatbot-package.css"
  },
  "scripts": {
    "build": "vite build",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "lucide-react": "^0.468.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  }
}
